{
  "enabled": true,
  "name": "Test Gate: Before Git Commit",
  "description": "Before running any shell command that includes 'git commit', automatically runs flutter test and blocks the commit if tests fail.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "shell"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A shell command is about to run. If it contains 'git commit', you MUST run `flutter test` first and confirm all tests pass before proceeding with the commit. If tests fail, fix them before committing — do not skip or bypass this check."
  }
}