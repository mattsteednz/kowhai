{
  "enabled": true,
  "name": "Remind: Analyze + Test After Edit",
  "description": "After writing or editing a file, reminds the agent to run flutter analyze and flutter test before committing.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A file was just written or edited. Remind yourself: run `flutter analyze --fatal-warnings` and `flutter test` before committing. If you are about to commit, run both checks now and confirm they pass first."
  }
}
